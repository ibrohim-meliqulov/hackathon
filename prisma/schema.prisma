generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SUPERADMIN
}

model User {
  id         Int      @id @default(autoincrement())
  phone      String   @unique
  password   String
  name       String
  surname    String
  birth_date DateTime
  region     String
  role       UserRole
}
