generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SUPERADMIN
}

model User {
  id        Int        @id @default(autoincrement())
  phone     String     @unique
  password  String
  name      String
  surname   String
  region    String
  role      UserRole
  plantings Planting[]
}

model Planting {
  id          Int       @id @default(autoincrement())
  name        String
  type        String
  plantedDate DateTime
  area        Float
  harvestDate DateTime?

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
